# Laravel `/api` base for browser + SSR (e.g. https://api.example.com/api).
# Prefer 127.0.0.1 in local dev — `localhost` can resolve to IPv6 while `php artisan serve` is IPv4-only.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api

# PostHog project API key (public client key; EU region). Required for analytics — see PostHogProvider.
# NEXT_PUBLIC_POSTHOG_KEY=

# Google Analytics 4 measurement ID (production only; same property as tunzone.com).
# NEXT_PUBLIC_GA_MEASUREMENT_ID=

# If NEXT_PUBLIC_API_URL is omitted, marketplace calls use same-origin `/api/marketplace/*`, proxied by
# `src/app/api/marketplace/[[...path]]/route.ts` toward LARAVEL_API_ORIGIN (if set), else NEXT_PUBLIC_API_URL stripped, else http://127.0.0.1:8000.
#
# Armenia + Local: Route Handlers also call Laravel directly via getServerMarketplaceApiBaseUrl() using the same rules.

# Optional: storefront slug for interior_design usage metering (defaults to demo).
# Production (vista.tunzone.com): set INTERIOR_DESIGN_ADMIN_SLUG to a published, subscribed merchant slug —
# picked up at runtime after pm2 restart (no rebuild). NEXT_PUBLIC_* requires rebuild if used alone.
INTERIOR_DESIGN_ADMIN_SLUG=
NEXT_PUBLIC_INTERIOR_ADMIN_SLUG=demo

# Server-side keys for /api/interior-design/generate and /api/project/*
ANTHROPIC_API_KEY=
# Google AI Studio often labels this as GEMINI_API_KEY — either works:
GOOGLE_AI_API_KEY=
# GEMINI_API_KEY=
# Floor-plan (Phase 1) analysis model — Gemini vision-to-JSON. Override if needed.
# FLOOR_PLAN_ANALYSIS_MODEL=gemini-2.5-pro

# Full Project render model: edit-pipeline (default) | kontext | apartment-staging
# VISTA_PROJECT_RENDER_MODEL=edit-pipeline
# Quick Room render engine: edit-pipeline (default; nano-banana edit + geometry validation,
# renders over SSE /api/interior-design/generate/stream) | legacy (Gemini single-shot POST).
# Degrades to legacy automatically when FAL_KEY is unset.
# VISTA_QUICK_RENDER_MODEL=edit-pipeline
# VISTA_RENDER_VALIDATE=1
# VISTA_EDIT_RESOLUTION=2K
# VISTA_VALIDATE_MODEL=gpt-4o-mini
# VISTA_FAL_ERASE_DILATE_PIXELS=12
# VISTA_CLAUDE_REQUEST_LOG=compact
# Legacy apartment-staging path (deprecated — use edit-pipeline):
# VISTA_STAGING_LAYERED=1
# VISTA_STAGING_LAYERED=0  # rollback to single-pass staging
# Optional flux denoise for layered shell/furnish when opening boxes force flux path:
# VISTA_FAL_SHELL_DENOISE=0.55
# VISTA_FAL_FURNISH_DENOISE=0.65
# Client-side cost estimates (mirror server vars above):
# NEXT_PUBLIC_VISTA_PROJECT_RENDER_MODEL=edit-pipeline
# NEXT_PUBLIC_VISTA_STAGING_LAYERED=1
# VISTA_RENDER_PROVIDER=gemini
# Full Project render engine (defaults to "fal" when unset; falls back to VISTA_RENDER_PROVIDER).
# VISTA_PROJECT_RENDER_PROVIDER=fal
# fal.ai API key — required when either provider is "fal" (also used for fal storage uploads).
# FAL_KEY=
# Two-stage FAL pipeline: Kontext when no user lines; ControlNet when Pro mode lines drawn.
# VISTA_FAL_KONTEXT_GUIDANCE=3.5
# VISTA_FAL_USER_LINE_CONTROL_STRENGTH=0.40
# fal tuning (optional): img2img strength, steps, guidance.
# VISTA_FAL_DENOISE=0.95
# VISTA_FAL_STEPS=28
# VISTA_FAL_GUIDANCE=3.5
# VISTA_FAL_IP_ADAPTER_SCALE=0.6
# Canny control-LoRA: conditioning scale (how hard the render follows the photo's edges)
# and an override for the LoRA weights path (correct here if fal moves the default):
# VISTA_FAL_CANNY_STRENGTH=0.35
# VISTA_FAL_CANNY_LORA_PATH=
# Release the Canny structural lock for the last fraction of sampling steps (0.8 = held
# for the first 80%, freed for the final 20%) so flux renders soft shadows, reflections,
# and fabric folds naturally instead of as a rigid CAD-like trace:
# VISTA_FAL_CONTROL_GUIDANCE_END=0.8
# Cross-viewpoint IP-Adapter scale: anchor strength when re-shooting a locked design from
# a SECOND camera. Lower than VISTA_FAL_IP_ADAPTER_SCALE so the anchor keeps the design's
# materials/finishes but NOT its composition — otherwise the 2nd viewpoint collapses back
# to the primary camera framing:
# VISTA_FAL_VIEWPOINT_IP_ADAPTER_SCALE=0.35
# Interior-design styling LoRA (optional, OFF unless set): bridges flux's flat/clinical look
# toward Gemini's richness (photoreal fabric, wood grain, soft ambient light). Must be a
# PUBLICLY fetchable .safetensors URL (e.g. an InteriorDesigner-Flux LoRA); fal downloads it
# server-side. Scale ~0.85 applies premium styling without distorting wall/bed placement:
# VISTA_FAL_STYLE_LORA_PATH=
# VISTA_FAL_STYLE_LORA_SCALE=0.85
# Flip if an e2e test shows mask polarity reversed (openings are the only thing that changes):
# VISTA_FAL_MASK_INVERT=1
# Set to 0 to skip the OpenAI opening-validation gate + retry:
# VISTA_FAL_VALIDATE=0
# Set to 0 to skip Gemini style-reference plate (faster local dev; less mood accuracy):
# VISTA_FAL_STYLE_PLATE=0
# Set to 1 to store photos/masks via Laravel instead of fal storage (prod-reachable origins only):
# VISTA_FAL_USE_BACKEND_STORAGE=1
# Set to 1 to show the manual window/door box-correction editor in Quick Room (feeds both fal mask + Gemini guide):
# NEXT_PUBLIC_VISTA_OPENING_EDITOR=1

# Optional: host:port where Node (Route Handlers / Docker) can reach PHP. No trailing slash, no `/api`.
# Use when NEXT_PUBLIC_API_URL is a public CDN URL but Laravel is on the private network or host.docker.internal.
# Example: http://127.0.0.1:8000 or http://host.docker.internal:8000
# LARAVEL_API_ORIGIN=http://127.0.0.1:8000

# Optional: required for internal usage consume endpoint if configured in Laravel
# INTERNAL_API_KEY=  # must match backend; enables slot-failure + AI issue emails to support

# Redis — project state for Full Project flow (SSE + room-by-room design)
REDIS_URL=redis://127.0.0.1:6379

# Optional: cap designable rooms in Full Project flow (local token debugging)
# NEXT_PUBLIC_DEBUG_MAX_ROOMS=2

# Dev-only live AI spend tracker (header badge + /api/dev/spend)
# NEXT_PUBLIC_VISTA_SHOW_SPEND=1
# VISTA_DEV_SPEND=1

# Hybrid placement validation (VLM boxes + deterministic geometry rules)
# VISTA_PLACEMENT_VALIDATE=0
